// =============================================================
//  my_keyboard.overlay
//  wasnt too bad either to write this custom using the boilerplate code from ZMKs github
// kinda peak ngl
// =============================================================

#include <dt-bindings/zmk/matrix_transform.h>

// ── I2C Bus (SDA = pin 20 = P0.17, SCL = pin 21 = P0.15) ────
&i2c0 {
    status = "okay";
    sda-pin = <17>;
    scl-pin = <15>;

    // ── OLED (SSD1306 0.91" 128x32) ──────────────────────────
    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-remap;
        com-invdir;
        com-sequential;
        prechargep = <0x22>;
    };

    // ── GPIO Expander (MCP23017 at address 0x20) ──────────────
    mcp23017: mcp23017@20 {
        compatible = "microchip,mcp230xx";
        status = "okay";
        reg = <0x20>;
        gpio-controller;
        #gpio-cells = <2>;
        ngpios = <16>;
    };
};

//  ADC for battery sensing
&adc {
    status = "okay";
};

/ {
    chosen {
        zmk,kscan     = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,display   = &oled;
        zmk,underglow = &led_strip;
        zmk,battery   = &vbatt;
    };

    default_transform: keymap_transform_0 {
        // ... existing code ...
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        row-gpios = <&gpio0 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                    <&gpio0 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>,
                    <&gpio0 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
        col-gpios = <&gpio1 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>,
                    <&gpio1 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>,
                    <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>,
                    <&gpio1 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    };

    encoder: encoder {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "okay";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder>;
        triggers-per-rotation = <20>;
    };

    led_strip: ws2812 {
        compatible = "worldsemi,ws2812-spi";
        spi-max-frequency = <4000000>;
        chain-length = <82>;
        spi-one-frame  = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping  = <0 1 2>;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-voltage-divider";
        io-channels = <&adc 1>;
        output-ohms  = <820000>;
        full-ohms    = <2820000>;
    };
};
